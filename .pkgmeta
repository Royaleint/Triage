package-as: Triage

enable-nolib-creation: no
enable-toc-creation: yes

manual-changelog:
  filename: RELEASE_NOTES.md
  markup-type: markdown

ignore:
  - .git
  - .gitignore
  - .pkgmeta
  - .claude
  - .mcp.json
  - .luacheckrc
  - .env
  - "*.md"
  - "!README.md"
  - "!CHANGELOG.md"
  - Triage_Dev

embedded-libraries:
  - LibStub
  - CallbackHandler-1.0
  - AceAddon-3.0
  - AceBucket-3.0
  - AceComm-3.0
  - AceConfig-3.0
  - AceConsole-3.0
  - AceDB-3.0
  - AceDBOptions-3.0
  - AceEvent-3.0
  - AceGUI-3.0
  - AceHook-3.0
  - AceLocale-3.0
  - AceSerializer-3.0
  - AceTab-3.0
  - AceTimer-3.0
  - AceGUI-3.0-SharedMediaWidgets
  - LibSharedMedia-3.0
  - LibDeflate
  - LibDualSpec-1.0
  - LibRangeCheck-3.0
  - LibClassicDurations
  - LibDispel
  - LibCustomGlow
  - LibDataBroker-1.1
  - LibDBIcon-1.0
